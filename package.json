{
  "name": "@lvce-editor/extension-management-worker-monorepo",
  "version": "0.0.0-dev",
  "license": "MIT",
  "author": "Lvce Editor",
  "type": "module",
  "main": "src/extensionManagementWorkerMain.ts",
  "workspaces": [
    "packages/*"
  ],
  "directories": {
    "test": "test"
  },
  "scripts": {
    "build": "node packages/build/src/build.js",
    "build:static": "node packages/build/src/build-static.ts",
    "build:watch": "npm exec --workspace=packages/build -- esbuild --external:node:buffer --external:electron --external:ws --external:node:worker_threads --format=esm --bundle --watch packages/extension-management-worker/src/extensionManagementWorkerMain.ts --outfile=.tmp/dist/dist/extensionManagementWorkerMain.js",
    "dev": "node packages/build/src/dev.js",
    "format": "prettier --write .",
    "lint": "eslint . && prettier --check . && knip --no-config-hints",
    "measure": "npm run measure --workspace=packages/memory",
    "test": "npm test --workspaces --if-present",
    "type-check": "tsc -b"
  },
  "prettier": {
    "semi": false,
    "singleQuote": true,
    "printWidth": 150
  },
  "devDependencies": {
    "@lvce-editor/eslint-config": "^17.0.3",
    "@lvce-editor/eslint-plugin-github-actions": "^17.0.0",
    "eslint": "^10.7.0",
    "knip": "^6.27.0",
    "prettier": "^3.9.5",
    "typescript": "^6.0.3"
  }
}
